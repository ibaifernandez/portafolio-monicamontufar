---
import Layout from "../layouts/Layout.astro";
import CaseStudyLayout from "../layouts/CaseStudyLayout.astro";
import CaseStudyHero from "../components/CaseStudyHero.astro";
import CaseStudyResults from "../components/CaseStudyResults.astro";
import CaseStudyStack from "../components/CaseStudyStack.astro";
import CaseStudyFlipbook from "../components/CaseStudyFlipbook.astro";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);

const isEs = lang === 'es';

const content = {
  hero: {
    category: isEs ? "CASO LEBEN" : "LEBEN CASE",
    title: isEs ? "De 69,000 contactos inactivos a un 40% de apertura: El caso Inmobiliaria Leben" : "From 69,000 inactive contacts to a 40% open rate: The Inmobiliaria Leben Case",
    description: isEs ? "Una migración crítica y una limpieza profunda de datos que rescataron la reputación de un dominio en riesgo." : "A critical migration and deep data cleansing that rescued the reputation of a domain at risk.",
    bgImage: "/images/cases/caso1-hero.jpg"
  },
  results: {
    title: isEs ? "Métricas de Éxito" : "Success Metrics",
    metrics: [
      { 
        icon: "🚀", 
        label: isEs ? "Crecimiento de Apertura" : "Open Rate Growth", 
        desc: isEs ? "Elevé la tasa de apertura de un 8.6% a un pico del 39.6%, multiplicando casi por 5 el alcance real y el interés de la audiencia en cada envío." : "I increased the open rate from 8.6% to a peak of 39.6%, multiplying the real reach and audience interest by nearly 5 with each delivery." 
      },
      { 
        icon: "🛡️", 
        label: isEs ? "Salud y Entregabilidad" : "Health & Deliverability", 
        desc: isEs ? "Logré una limpieza profunda que redujo los rebotes duros de 4,087 a solo 5, blindando la reputación del dominio ante proveedores como Microsoft y Google." : "I achieved deep cleansing that reduced hard bounces from 4,087 to just 5, shielding the domain reputation before providers like Microsoft and Google." 
      },
      { 
        icon: "📈", 
        label: isEs ? "Conversión y Clics" : "Conversion & Clicks", 
        desc: isEs ? "Incrementé el CTR de 0.92% a 3.70% mediante la implementación de plantillas UX interactivas y llamadas a la acción directas hacia WhatsApp y proyectos." : "I increased the CTR from 0.92% to 3.70% by implementing interactive UX templates and direct calls to action to WhatsApp and projects." 
      }
    ],
    images: ["/images/cases/caso1-res1.jpg", "/images/cases/caso1-res2.jpg", "/images/cases/caso1-res3.jpg"]
  },
  stack: [
    {
      title: isEs ? "Estrategia de Migración" : "Migration Strategy",
      desc: isEs ? "Ejecuté la transición técnica de Mailchimp a Brevo, incluyendo procesos de Warm-up de IP y configuración de protocolos de autenticación para asegurar el buzón de entrada." : "I executed the technical transition from Mailchimp to Brevo, including IP Warm-up processes and configuration of authentication protocols to ensure inbox delivery.",
      image: "/images/cases/caso1-res1.jpg"
    },
    {
      title: isEs ? "Data & SQL" : "Data & SQL",
      desc: isEs ? "Utilicé consultas de SQL y lógica de datos para segmentar una base masiva de 69,000 registros, priorizando a los 11,000 usuarios con mayor potencial de conversión." : "I used SQL queries and data logic to segment a massive database of 69,000 records, prioritizing the 11,000 users with the greatest conversion potential.",
      image: "/images/cases/caso1-res2.jpg"
    },
    {
      title: isEs ? "Diseño & HTML" : "Design & HTML",
      desc: isEs ? "Desarrollé estructuras de HTML optimizado con jerarquía visual de alta conversión, garantizando una visualización perfecta y profesional en dispositivos móviles y escritorio." : "I developed optimized HTML structures with high-conversion visual hierarchy, ensuring a perfect and professional display on mobile devices and desktops.",
      image: "/images/cases/caso1-res3.jpg"
    }
  ],
  pdfUrl: "/images/cases/caso1.pdf"
};
---

<CaseStudyLayout title={content.hero.title} description={content.hero.description}>
  <main>
    <CaseStudyHero {...content.hero} />
    <CaseStudyResults {...content.results} />
    <CaseStudyStack items={content.stack} />
    <CaseStudyFlipbook pdfUrl={content.pdfUrl} />
  </main>
</CaseStudyLayout>
