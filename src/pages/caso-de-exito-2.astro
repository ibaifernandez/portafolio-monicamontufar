---
import Layout from "../layouts/Layout.astro";
import CaseStudyLayout from "../layouts/CaseStudyLayout.astro";
import CaseStudyHero from "../components/CaseStudyHero.astro";
import CaseStudyResults from "../components/CaseStudyResults.astro";
import CaseStudyStack from "../components/CaseStudyStack.astro";
import CaseStudyFlipbook from "../components/CaseStudyFlipbook.astro";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const isEs = lang === 'es';

const content = {
  hero: {
    category: isEs ? "CASO CLÍNICA COSTANERA" : "CLINICA COSTANERA CASE",
    title: isEs ? "Seguridad Digital y Gobierno de Datos: El caso Clínica Costanera" : "Digital Security and Data Governance: The Clinica Costanera Case",
    description: isEs ? "Implementación de protocolos de seguridad avanzada y optimización de engagement para un sector altamente regulado." : "Implementation of advanced security protocols and engagement optimization for a highly regulated sector.",
    bgImage: "/images/cases/caso2-hero.png"
  },
  results: {
    title: isEs ? "Gestión de Rendimiento" : "Performance Management",
    metrics: [
      { 
        icon: "🛡️", 
        label: isEs ? "Blindaje de Reputación" : "Reputation Shielding", 
        desc: isEs ? "Implementación técnica de DMARC, SPF y DKIM para asegurar la integridad de las comunicaciones médicas y evitar suplantaciones." : "Technical implementation of DMARC, SPF, and DKIM to ensure medical communication integrity and prevent spoofing." 
      },
      { 
        icon: "📈", 
        label: isEs ? "Optimización del Engagement" : "Engagement Optimization", 
        desc: isEs ? "Aumento sostenido en la tasa de apertura mediante personalización dinámica basada en el historial de citas y especialidades médicas." : "Sustained increase in open rates through dynamic personalization based on appointment history and medical specialties." 
      },
      { 
        icon: "⚖️", 
        label: isEs ? "Gobierno de Datos" : "Data Governance", 
        desc: isEs ? "Auditoría y limpieza de datos bajo normativas HIPAA y GDPR, asegurando el tratamiento ético y seguro de información sensible." : "Data auditing and cleansing under HIPAA and GDPR regulations, ensuring ethical and secure handling of sensitive information." 
      }
    ],
    images: ["/images/cases/caso2-res1.jpg", "/images/cases/caso2-res2.jpg", "/images/cases/caso2-res3.jpg"]
  },
  stack: [
    {
      title: isEs ? "Protocolos de Seguridad" : "Security Protocols",
      desc: isEs ? "Configuración de capas de autenticación avanzada para proteger la privacidad del paciente y la integridad del dominio institucional." : "Configuration of advanced authentication layers to protect patient privacy and institutional domain integrity.",
      image: "/images/cases/caso2-res2.jpg"
    },
    {
      title: isEs ? "Proveedores de Servicio" : "Service Providers",
      desc: isEs ? "Evaluación y migración a infraestructuras de envío de alta reputación médica, garantizando tasas de entrega superiores al 99%." : "Evaluation and migration to high-reputation medical delivery infrastructures, guaranteeing delivery rates above 99%.",
      image: "/images/cases/caso2-res3.jpg"
    },
    {
      title: isEs ? "Control de Accesos" : "Access Control",
      desc: isEs ? "Segmentación técnica de bases de datos para limitar el acceso a información sensible según el rol del personal administrativo." : "Technical database segmentation to limit sensitive information access based on administrative staff role.",
      image: "/images/cases/caso2-res4.jpg"
    }
  ],
  pdfUrl: "/images/cases/caso2.pdf"
};
---

<CaseStudyLayout title={content.hero.title} description={content.hero.description}>
  <main>
    <CaseStudyHero {...content.hero} />
    <CaseStudyResults {...content.results} />
    <CaseStudyStack items={content.stack} />
    <CaseStudyFlipbook pdfUrl={content.pdfUrl} />
  </main>
</CaseStudyLayout>
