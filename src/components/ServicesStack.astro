---
// src/components/ServicesStack.astro
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  {
    title: lang === 'es' ? "Arquitectura de Flujos de Automatización" : "Automation Flow Architecture",
    description: lang === 'es' ? "Diseño y configuración de ecosistemas de correos automatizados basados en el comportamiento del usuario (triggers), optimizando el ciclo de vida del cliente desde el lead magnet hasta la post-venta." : "Design and configuration of automated email ecosystems based on user behavior (triggers), optimizing the customer lifecycle from lead magnet to post-sale."
  },
  {
    title: lang === 'es' ? "Gestión de Entregabilidad y Reputación" : "Deliverability & Reputation Management",
    description: lang === 'es' ? "Implementación técnica de protocolos de autenticación (SPF, DKIM, DMARC) y monitoreo de salud del dominio para asegurar que los mensajes lleguen a la bandeja de entrada, no a spam." : "Technical implementation of authentication protocols (SPF, DKIM, DMARC) and domain health monitoring to ensure messages hit the inbox, not spam."
  },
  {
    title: lang === 'es' ? "Segmentación Predictiva y Gestión de Listas" : "Predictive Segmentation & List Management",
    description: lang === 'es' ? "Organización de bases de datos mediante etiquetas y campos personalizados, permitiendo enviar el mensaje correcto al usuario adecuado según su nivel de interacción y hábitos de compra." : "Database organization using tags and custom fields, allowing you to send the right message to the right user based on their interaction level and buying habits."
  },
  {
    title: lang === 'es' ? "Análisis de Métricas y Optimización A/B" : "Metrics Analysis & A/B Optimization",
    description: lang === 'es' ? "Interpretación de datos complejos para ejecutar pruebas A/B rigurosas sobre elementos clave, transformando los reportes estadísticos en decisiones estratégicas de crecimiento." : "Interpretation of complex data to execute rigorous A/B testing on key elements, transforming statistical reports into strategic growth decisions."
  },
  {
    title: lang === 'es' ? "Diseño Responsive y UX para Email" : "Responsive Design & UX for Email",
    description: lang === 'es' ? "Creación de plantillas visualmente atractivas y accesibles que garantizan una experiencia de lectura perfecta en cualquier dispositivo, priorizando siempre la jerarquía visual hacia la conversión." : "Creation of visually appealing and accessible templates that guarantee a perfect reading experience on any device, always prioritizing visual hierarchy towards conversion."
  },
  {
    title: lang === 'es' ? "Estrategia de First-Party Data y Cumplimiento" : "First-Party Data Strategy & Compliance",
    description: lang === 'es' ? "Recolección y uso ético de datos proporcionados directamente por el usuario para enriquecer perfiles, asegurando el cumplimiento de normativas de privacidad (GDPR/CAN-SPAM)." : "Ethical collection and use of data provided directly by the user to enrich profiles, ensuring compliance with privacy regulations (GDPR/CAN-SPAM)."
  }
];
---
<section class="py-24 relative" id="servicios">
  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight">{t('stack.title')} <span class="text-brand-salmon">{t('stack.title_accent')}</span> {t('stack.title_end')}</h2>
      <p class="text-xl text-gray-400 mt-6 leading-relaxed">
        {lang === 'es' ? "Estratega de Email Marketing especializado en optimizar el ciclo de vida del cliente a través de segmentación predictiva, entregabilidad técnica y experimentación basada en datos." : "Email Marketing Strategist specialized in optimizing the customer lifecycle through predictive segmentation, technical deliverability and data-driven experimentation."}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, idx) => (
        <div class="group bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-2xl hover:bg-white/10 hover:border-brand-salmon/50 hover:-translate-y-2 transition-all duration-300 relative overflow-hidden shadow-xl hover:shadow-brand-salmon/10 cursor-default">
          <div class="absolute top-0 left-0 w-1 h-full bg-brand-salmon transform scale-y-0 group-hover:scale-y-100 transition-transform duration-300 origin-bottom"></div>
          
          <div class="text-5xl font-black text-white/5 absolute -right-4 -top-6 group-hover:text-brand-cyan/10 transition-colors duration-300">
            0{idx + 1}
          </div>
          
          <h3 class="text-xl font-bold text-white mb-4 pr-6 group-hover:text-brand-salmon transition-colors">
            {service.title}
          </h3>
          <p class="text-gray-400 leading-relaxed text-sm md:text-base">
            {service.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
