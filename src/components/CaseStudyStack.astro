---
interface Props {
  items: { title: string; desc: string; image: string }[];
}
const { items } = Astro.props;
---
<section class="py-32 bg-[#F7FAFC] border-y border-gray-200 relative">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="text-center mb-20">
       <span class="text-brand-orange font-bold uppercase text-xs tracking-[0.3em] mb-4 block">IMPLEMENTACIÓN AVANZADA</span>
       <h2 class="text-4xl md:text-5xl font-black text-brand-bg tracking-tight">Stack Tecnológico</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {items.map(item => (
        <div class="group bg-white p-8 rounded-3xl border border-gray-100 hover:border-brand-salmon/50 hover:-translate-y-2 transition-all duration-500 shadow-sm hover:shadow-xl">
          <div class="aspect-video w-full overflow-hidden rounded-2xl mb-8 relative bg-gray-50">
            <img 
              src={item.image} 
              class="w-full h-full object-cover grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700" 
              alt={item.title} 
            />
          </div>
          <h4 class="text-2xl font-bold text-brand-bg mb-4 group-hover:text-brand-salmon transition-colors">{item.title}</h4>
          <p class="text-gray-600 leading-relaxed text-sm md:text-base opacity-90 group-hover:opacity-100 transition-opacity">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
