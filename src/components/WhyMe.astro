---
// src/components/WhyMe.astro
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="py-24 relative overflow-hidden" id="por-que-elegirme">
  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Text content -->
      <div>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">
          {t('whyme.title')} <span class="text-brand-salmon">{t('whyme.title_accent')}</span>?
        </h2>
        <p class="text-xl text-gray-300 leading-relaxed font-light mb-10">
          {lang === 'es' ? "No solo envío correos; construyo canales de venta automatizados, rentables y técnicamente impecables. Mi enfoque une la ciencia de los datos con la psicología del usuario para garantizar que cada mensaje aporte valor real a tu balance de resultados." : "I don't just send emails; I build automated, profitable, and technically flawless sales channels. My approach combines data science with user psychology to ensure that every message adds real value to your bottom line."}
        </p>

        <div class="space-y-8">
          <div class="flex gap-4 group">
            <div class="flex-shrink-0 mt-1">
              <div class="w-12 h-12 rounded-full bg-brand-cyan/10 flex items-center justify-center border border-brand-cyan/30 text-brand-cyan group-hover:bg-brand-cyan group-hover:text-brand-bg transition-colors duration-300">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
              </div>
            </div>
            <div>
              <h4 class="text-xl font-bold text-white mb-2">Enfoque ROI Real</h4>
              <p class="text-gray-400">Diseño estrategias orientadas a la conversión y retención, convirtiendo tu base de datos en un activo financiero predecible.</p>
            </div>
          </div>
          <div class="flex gap-4 group">
            <div class="flex-shrink-0 mt-1">
              <div class="w-12 h-12 rounded-full bg-brand-magenta/10 flex items-center justify-center border border-brand-magenta/30 text-brand-magenta group-hover:bg-brand-magenta group-hover:text-white transition-colors duration-300">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
              </div>
            </div>
            <div>
              <h4 class="text-xl font-bold text-white mb-2">Blindaje Técnico y Privacidad</h4>
              <p class="text-gray-400">Aseguro que tus correos lleguen a la bandeja de entrada cumpliendo estrictamente con las normativas de datos (GDPR/DMARC).</p>
            </div>
          </div>
          <div class="flex gap-4 group">
            <div class="flex-shrink-0 mt-1">
              <div class="w-12 h-12 rounded-full bg-brand-orange/10 flex items-center justify-center border border-brand-orange/30 text-brand-orange group-hover:bg-brand-orange group-hover:text-white transition-colors duration-300">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
              </div>
            </div>
            <div>
              <h4 class="text-xl font-bold text-white mb-2">Optimización Basada en Evidencia</h4>
              <p class="text-gray-400">Sustituyo las suposiciones por pruebas A/B y análisis de datos, garantizando una mejora continua en cada métrica clave.</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Image Graphic -->
      <div class="relative flex justify-center lg:justify-end mt-10 lg:mt-0">
        <div class="w-full max-w-[400px] aspect-square rounded-[3rem] bg-white/5 border border-white/10 backdrop-blur-sm p-4 relative shadow-[0_0_40px_rgba(0,0,0,0.4)] group">
          <div class="absolute inset-0 bg-gradient-to-tr from-brand-salmon/20 to-brand-cyan/20 blur-2xl group-hover:blur-3xl transition-all duration-700"></div>
          <img src="/images/Mon.png" alt="Mónica Montúfar Nómada Digital" class="w-full h-full object-cover rounded-[2.5rem] object-[50%_20%] opacity-80 mix-blend-luminosity filter contrast-125 group-hover:mix-blend-normal group-hover:opacity-100 transition-all duration-700" loading="lazy" />
        </div>
      </div>

    </div>
  </div>
</section>
