---
// src/components/ClientBanner.astro
// Auto-scrolling marquee of client logos
const logos = [
  { src: '/images/logos/Logo-Amarenno.png', alt: 'Amarenno' },
  { src: '/images/logos/clientes-02.jpg', alt: 'Leben' },
  { src: '/images/logos/clientes-03.jpg', alt: 'Viva la funda' },
  { src: '/images/logos/Kombutxa-Indika-logo.png', alt: 'Kombutxa Indika' },
  { src: '/images/logos/clientes-04.jpg', alt: 'Cliente 4' },
  { src: '/images/logos/clientes-05.jpg', alt: 'Arval' },
  { src: '/images/logos/clientes-06.jpg', alt: 'Cliente 6' },
  { src: '/images/logos/Chokilate.png', alt: 'Chokolate' },
  { src: '/images/logos/Bauqero.png', alt: 'Bauqero' },
];
---

<section class="w-full bg-white py-10 border-y border-gray-100 overflow-hidden">
  <div class="relative flex gap-0 marquee-container">
    <!-- Track duplicated for seamless loop -->
    {[0, 1].map(() => (
      <div class="flex items-center gap-12 shrink-0 marquee-track px-6">
        {logos.map(logo => (
          <div class="hover:scale-110 transition-transform duration-300 ease-in-out cursor-pointer hover:drop-shadow-sm flex-shrink-0">
            <img 
              src={logo.src} 
              alt={logo.alt} 
              class="h-14 md:h-16 object-contain max-w-[140px] mix-blend-multiply"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    ))}
  </div>
</section>

<style>
  .marquee-container {
    width: 100%;
  }
  .marquee-track {
    animation: marquee-scroll 30s linear infinite;
  }
  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  /* Pause on hover */
  .marquee-container:hover .marquee-track {
    animation-play-state: paused;
  }
</style>
