---
// src/components/ClientBanner.astro
const logos = [
  { src: '/images/logos/Logo-Amarenno.png', alt: 'Amarenno' },
  { src: '/images/logos/clientes-02.jpg', alt: 'Leben' }, 
  { src: '/images/logos/clientes-03.jpg', alt: 'Viva la funda' },
  { src: '/images/logos/Kombutxa-Indika-logo.png', alt: 'Kombutxa Indika' },
  { src: '/images/logos/clientes-05.jpg', alt: 'Arval' },
  { src: '/images/logos/Chokilate.png', alt: 'Chokolate' }
];

// Fallback logic inside: we just map through the logos. The JPGs (clientes-XX) were extracted dynamically.
---

<section class="w-full bg-white py-10 border-y border-gray-100">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="flex flex-wrap justify-center md:justify-between items-center gap-8 lg:gap-12">
      {logos.map(logo => (
        <div class="hover:scale-110 transition-transform duration-300 ease-in-out cursor-pointer hover:drop-shadow-sm">
          <img 
            src={logo.src} 
            alt={logo.alt} 
            class="h-12 md:h-16 lg:h-20 object-contain max-w-[150px] md:max-w-none mix-blend-multiply"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
