---
interface Props {
  bgImage: string;
  category: string;
  title: string;
  description: string;
}
const { bgImage, category, title, description } = Astro.props;
---
<section class="relative min-h-[70vh] flex items-center pt-32 pb-20 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img src={bgImage} class="w-full h-full object-cover" alt="" />
    <div class="absolute inset-0 bg-black/70 backdrop-blur-[1px]"></div>
  </div>
  
  <div class="container mx-auto px-6 max-w-7xl relative z-10 mt-12">
    <div class="max-w-4xl">
      <span class="text-brand-orange font-bold tracking-[0.3em] uppercase text-sm mb-6 block animate-fade-in">
        {category}
      </span>
      <h1 class="text-4xl md:text-7xl font-bold text-white mb-8 leading-[1.1] tracking-tight">
        {title}
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 font-light leading-relaxed max-w-3xl opacity-90">
        {description}
      </p>
    </div>
  </div>

  <!-- Top Right Logo Overlay -->
  <div class="absolute top-12 right-12 z-20 hidden md:block">
    <img src="/images/cases/logo-mon.png" alt="Mónica Montúfar" class="w-16 h-16 object-contain" />
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }
</style>
