---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
  {
    title: lang === 'es' ? "Del 8% al 40% en tasa de apertura." : "From 8% to 40% in open rate.",
    image: "/images/Caso-exito-1_portada.jpg",
    link: lang === 'es' ? "/caso-de-exito-1" : "/en/case-study-1"
  },
  {
    title: lang === 'es' ? "Blindaje de Reputación y DNS" : "Reputation and DNS Shielding",
    image: "/images/PORTAFOLIO-CAO-DE-EXITO-2.jpg",
    link: lang === 'es' ? "/caso-de-exito-2" : "/en/case-study-2"
  }
];
---
<section class="py-24 relative" id="portafolio">
  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight">{t('portfolio.title')} <br/><span class="text-brand-salmon">{t('portfolio.title_accent')}</span></h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {projects.map(project => (
        <a href={project.link} class="group block relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 shadow-2xl">
          <div class="aspect-[4/3] sm:aspect-video w-full overflow-hidden">
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out" 
              loading="lazy" 
            />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-brand-bg via-brand-bg/60 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300"></div>
          
          <div class="absolute bottom-0 left-0 w-full p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-2xl font-bold text-white mb-4 line-clamp-2">{project.title}</h3>
            <span class="inline-flex items-center gap-2 text-brand-salmon font-semibold group-hover:text-white transition-colors">
              Descubre como <span class="text-xl">↗</span>
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
