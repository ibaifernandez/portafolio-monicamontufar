---
interface Props {
  title: string;
  metrics: { icon: string; label: string; desc: string }[];
  images: string[];
}
const { title, metrics, images } = Astro.props;
---
<section class="py-32 relative overflow-hidden bg-white text-brand-bg">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      
      <!-- Collage Left -->
      <div class="relative h-[450px] md:h-[550px] w-full max-w-[500px] mx-auto lg:mx-0">
        <!-- Background Shadow/Blur -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] h-[90%] bg-brand-bg/5 blur-[100px] -z-10 rounded-full"></div>
        
        <!-- Main centerpiece -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[85%] aspect-square rounded-[2rem] overflow-hidden shadow-2xl z-20 border-4 border-white">
          {images[2] && <img src={images[2]} class="w-full h-full object-cover" alt="" />}
        </div>
        <!-- Top Left -->
        <div class="absolute top-0 left-0 w-[60%] aspect-video rounded-2xl overflow-hidden shadow-xl z-10 opacity-90 rotate-[-4deg] border border-gray-100">
          {images[0] && <img src={images[0]} class="w-full h-full object-cover" alt="" />}
        </div>
        <!-- Bottom Right -->
        <div class="absolute bottom-4 right-0 w-[60%] aspect-video rounded-2xl overflow-hidden shadow-xl z-30 opacity-95 rotate-[4deg] border border-gray-100">
          {images[1] && <img src={images[1]} class="w-full h-full object-cover" alt="" />}
        </div>
      </div>

      <!-- Content Right -->
      <div class="relative">
        <span class="text-brand-orange font-bold uppercase text-xs tracking-[0.2em] mb-4 block">RESULTADOS REALES</span>
        <h2 class="text-4xl md:text-5xl font-black text-brand-bg mb-12 tracking-tight leading-tight">{title}</h2>
        
        <div class="space-y-10">
          {metrics.map(m => (
            <div class="flex gap-6 group">
              <div class="flex-shrink-0 w-14 h-14 bg-gray-50 border border-gray-200 rounded-xl flex items-center justify-center text-3xl group-hover:bg-brand-orange/10 group-hover:border-brand-orange/30 transition-all duration-300">
                {m.icon}
              </div>
              <div>
                <h4 class="font-bold text-gray-900 text-xl mb-1 group-hover:text-brand-orange transition-colors">{m.label}</h4>
                <p class="text-gray-600 leading-relaxed text-base max-w-md">{m.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
