---
// src/components/Skills.astro
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const skills = [
  { name: "Ecosistemas CRM & ESP", desc: lang === 'es' ? "Salesforce Marketing Cloud, ActiveCampaign, Mailchimp y Brevo." : "Salesforce Marketing Cloud, ActiveCampaign, Mailchimp and Brevo.", percent: 95 },
  { name: "Análisis de Datos con SQL", desc: lang === 'es' ? "Extracción y manipulación de bases de datos para segmentación." : "Data extraction and manipulation for segmentation.", percent: 85 },
  { name: "UI/UX para Email Mkt.", desc: lang === 'es' ? "Especialista en Diseño Gráfico, Web y Multimedia orientado a la experiencia de usuario." : "Graphic, Web and Multimedia Design specialist oriented to user experience.", percent: 90 },
  { name: "HTML & CSS para Email", desc: lang === 'es' ? "Maquetación de plantillas optimizadas para máxima entregabilidad y visualización móvil." : "Optimized template coding for maximum deliverability and mobile display.", percent: 98 },
  { name: "Automatización Multicanal", desc: lang === 'es' ? "Configuración de flujos lógicos en plataformas como MailerLite, Brevo y SMC." : "Configuration of logical flows in platforms such as MailerLite, Brevo and SMC.", percent: 92 },
  { name: "Gestión de Privacidad y Compliance", desc: lang === 'es' ? "Auditoría técnica en normativas de datos y protocolos de seguridad." : "Technical audit on data regulations and security protocols.", percent: 88 },
  { name: "Ingeniería de Experimentación", desc: lang === 'es' ? "Ejecución técnica de testeo multivariante basado en evidencia estadística." : "Technical execution of multivariate testing based on statistical evidence.", percent: 85 },
  { name: "Arquitectura de Datos con IA", desc: lang === 'es' ? "Uso de Inteligencia Artificial para el análisis predictivo y optimización de campañas." : "Use of AI for predictive analysis and campaign optimization.", percent: 80 }
];
---
<section class="py-24 bg-white/5 border-y border-white/10" id="habilidades">
  <div class="container mx-auto px-6 max-w-7xl">
    
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight">{t('skills.title')} <br/><span class="text-brand-salmon">{t('skills.title_accent')}</span></h2>
      <p class="text-xl text-gray-400 mt-6 max-w-2xl">
        {lang === 'es' ? "Mi experiencia y formación se centran en estas áreas clave, diseñadas para ofrecerte un soporte completo y de alto impacto." : "My experience and training focus on these key areas, designed to offer you full, high-impact support."}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12">
      {skills.map(skill => (
        <div class="group">
          <div class="flex justify-between items-end mb-2">
            <h4 class="text-lg font-bold text-white group-hover:text-brand-cyan transition-colors">{skill.name}</h4>
            <span class="text-sm font-mono text-brand-salmon font-bold">{skill.percent}%</span>
          </div>
          <p class="text-sm text-gray-400 mb-5 min-h-[40px] leading-relaxed pr-8">{skill.desc}</p>
          
          <div class="w-full bg-white/10 rounded-full h-2 mb-4 overflow-hidden shadow-inner relative">
            <div 
              class="absolute top-0 left-0 bg-gradient-to-r from-brand-salmon to-brand-cyan h-2 rounded-full transition-all duration-1000 ease-out" 
              style={`width: ${skill.percent}%`}
            >
              <!-- Sparkle indicator at the end of progress bar -->
              <div class="absolute right-0 top-0 bottom-0 w-2 bg-white/40 blur-[1px]"></div>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
