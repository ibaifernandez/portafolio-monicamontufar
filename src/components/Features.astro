---
// src/components/Features.astro
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="py-20 relative overflow-hidden" id="fortalezas">
  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight">{t('features.title')} <span class="text-brand-salmon">{t('features.title_accent')}</span></h2>
      <h3 class="text-2xl font-light text-brand-cyan mt-4">{t('features.subtitle')}</h3>
    </div>
    
    <div class="max-w-4xl mx-auto bg-white/5 backdrop-blur-lg border border-white/10 p-8 md:p-12 rounded-3xl shadow-[0_0_50px_rgba(0,0,0,0.5)] relative overflow-hidden">
      <!-- Glow effect -->
      <div class="absolute -top-10 -right-10 w-40 h-40 bg-brand-salmon/20 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-brand-cyan/10 rounded-full blur-3xl pointer-events-none"></div>
      
      <p class="text-xl md:text-2xl text-gray-300 leading-relaxed font-light text-center mb-12 relative z-10">
        Transformo bases de datos en motores de ingresos mediante arquitectura de automatización avanzada y estrategias de <strong class="text-white font-medium">First-Party Data</strong> de alto impacto.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 border-t border-white/10 pt-10 relative z-10">
        <div>
          <h4 class="text-sm uppercase tracking-widest text-brand-cyan font-bold mb-4">Identidad</h4>
          <ul class="space-y-3">
            <li class="flex items-center gap-2"><span class="text-brand-salmon bg-brand-salmon/10 p-1.5 rounded-md"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg></span> <span class="text-gray-400 mr-1">Nombre:</span> Mónica Montúfar</li>
            <li class="flex items-center gap-2"><span class="text-brand-salmon bg-brand-salmon/10 p-1.5 rounded-md"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg></span> <span class="text-gray-400 mr-1">Perfil:</span> Nómada digital</li>
            <li class="flex items-center gap-2"><span class="text-brand-salmon bg-brand-salmon/10 p-1.5 rounded-md"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg></span> <span class="text-gray-400 mr-1">Ubicación actual:</span> Colombia</li>
          </ul>
        </div>
        
        <div>
          <h4 class="text-sm uppercase tracking-widest text-brand-cyan font-bold mb-4">Presencia Profesional</h4>
          <div class="flex flex-wrap gap-3">
            <a href="#" class="px-4 py-2 bg-white/5 hover:bg-brand-salmon hover:text-white border border-white/10 hover:border-brand-salmon rounded-full text-sm font-medium transition-all duration-300">LinkedIn</a>
            <a href="#" class="px-4 py-2 bg-white/5 hover:bg-brand-salmon hover:text-white border border-white/10 hover:border-brand-salmon rounded-full text-sm font-medium transition-all duration-300">Workana</a>
            <a href="#" class="px-4 py-2 bg-white/5 hover:bg-brand-salmon hover:text-white border border-white/10 hover:border-brand-salmon rounded-full text-sm font-medium transition-all duration-300">SheWorks!</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
